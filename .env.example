# ============ Telegram ============
BOT_TOKEN=123456:AAAA-replace-with-real-token
# Несколько админов через запятую
ADMIN_IDS=12345678

# ============ 3x-ui панель ============
XUI_URL=https://152.114.195.76:60619
XUI_PATH=cK9tyS4K24k6gJELDS
XUI_USER=ahcugfKc6s
XUI_PASS=Cj7oPoexmy
# ID инбаунда VLESS-Reality (см. /panel → Inbounds → ID колонка)
XUI_INBOUND_ID=1
# True если у панели валидный TLS (Let's Encrypt). False — если самоподписанный
XUI_VERIFY_SSL=true

# ============ Параметры VLESS-ссылки ============
# (host/port/keys из инбаунда; не меняются при добавлении клиентов)
VLESS_HOST=152.114.195.76
VLESS_PORT=443
VLESS_PUBKEY=G255YLL7fFG4SRX9fliHC8Dm5wsNILVXRgg7A4nPKWU
VLESS_SHORT_ID=50ede7b43a10800d
VLESS_SNI=www.microsoft.com
VLESS_FLOW=xtls-rprx-vision
VLESS_FP=chrome

# ============ Платежи ============
# manual = админ выдаёт вручную через /grant; платежи отключены
# yookassa = ЮKassa для самозанятых
PAYMENT_MODE=manual

# Заполнить когда подключишь ЮKassa (registration → СЗ → API ключи)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_RETURN_URL=https://t.me/your_bot_name
# email для чеков НПД (обязателен по 54-ФЗ)
RECEIPT_EMAIL=client@example.com
# Описание услуги в чеке — НЕ писать слово VPN
RECEIPT_DESCRIPTION=Доступ к информационному сервису

# ============ Бренд / главное меню ============
# Ссылка на TG-канал. Пустая → кнопка "🌟 Наш канал" не показывается.
CHANNEL_URL=
# Текст для кнопки "ℹ️ О нас" — multiline разрешён через \n
ABOUT_TEXT=Atlas — быстрый и стабильный VPN на базе VLESS+Reality. Маскируется под обычный HTTPS-трафик.

# ============ Реферальная программа ============
# Сколько дней дарим реферреру за каждого оплатившего реферала
REFERRAL_BONUS_DAYS=7
REFERRAL_ENABLED=true

# ============ Прочее ============
DB_PATH=data/bot.db
# Каждые N секунд опрашивать ЮKassa на pending платежи
PAYMENT_POLL_INTERVAL=20
# Каждые N минут проверять подписки на истечение
SUB_CHECK_INTERVAL=10
