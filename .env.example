# ============ Платежи ============
# manual = админ выдаёт вручную через /grant; платежи отключены
# yookassa = ЮKassa для самозанятых
PAYMENT_MODE=manual

# Заполнить когда подключишь ЮKassa (registration → СЗ → API ключи)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET=
YOOKASSA_RETURN_URL=https://t.me/your_bot_name
# email для чеков НПД (обязателен по 54-ФЗ)
RECEIPT_EMAIL=client@example.com
# Описание услуги в чеке — НЕ писать слово VPN
RECEIPT_DESCRIPTION=Доступ к информационному сервису

# ============ Бренд / главное меню ============
# Ссылка на TG-канал. Пустая → кнопка "🌟 Наш канал" не показывается.
CHANNEL_URL=
# ABOUT_TEXT и OFFER_TEXT по умолчанию заданы в src/config.py.
# Если хочешь переопределить — раскомментируй и поставь однострочное значение
# (TG поймёт <b>...</b> как HTML, переносы строк через \n).
# ABOUT_TEXT=Atlas — самый быстрый VPN. <b>Жми</b>.
# OFFER_TEXT=Договор-оферта... текст одной строкой.

# ============ Реферальная программа ============
# Сколько дней дарим реферреру за каждого оплатившего реферала
REFERRAL_BONUS_DAYS=7
REFERRAL_ENABLED=true

# ============ Прочее ============
DB_PATH=data/bot.db
# Каждые N секунд опрашивать ЮKassa на pending платежи
PAYMENT_POLL_INTERVAL=20
# Каждые N минут проверять подписки на истечение
SUB_CHECK_INTERVAL=10
